<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Modifier le catway</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <%- include('partials/navbar') %>

<div class="form-container">
    <div class="form-card">

        <h1>Modifier un catway</h1>

        <form action="/catways/<%= catway._id %>?_method=PUT" method="POST">

            <div class="form-group">
                <label for="catwayNumber">Numéro du catway</label>
                <input
                    type="number"
                    id="catwayNumber"
                    name="catwayNumber"
                    value="<%= catway.catwayNumber %>"
                    required
                >
            </div>

            <div class="form-group">
                <label for="type">Type du catway</label>

                <select id="type" name="type" required>
                    <option value="Short" <%= catway.type === 'Short' ? 'selected' : '' %>>
                        Short
                    </option>

                    <option value="Long" <%= catway.type === 'Long' ? 'selected' : '' %>>
                        Long
                    </option>
                </select>
            </div>

            <div class="form-group">
                <label for="catwayState">État du catway</label>

                <textarea
                    id="catwayState"
                    name="catwayState"
                    required
                ><%= catway.catwayState %></textarea>
            </div>

            <button type="submit" class="btn-submit">
                Modifier le catway
            </button>

        </form>

        <a href="/catways/list">Retour aux catways</a>

    </div>
</div>

              
            </form>
        </section>
    </main>
    
</body>
</html>